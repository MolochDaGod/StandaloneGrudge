{
  "name": "grudge-warlords-mmo",
  "version": "1.0.0",
  "description": "Grudge Warlords MMO - Server infrastructure and deployment tools",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "build": "bash scripts/build-server.sh",
    "deploy": "bash scripts/deploy-to-vps.sh",
    "cli": "node scripts/grudge-cli.js",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "mmo",
    "game-server",
    "unity",
    "grudge-warlords"
  ],
  "author": "Grudge Warlords Team",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "pg": "^8.11.0",
    "redis": "^4.6.7",
    "winston": "^3.9.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.22"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  "name": "grudge-warlords",
  "version": "1.0.0",
  "type": "module",
  "description": "Final Fantasy 7-inspired turn-based RPG with multi-hero tactical combat",
  "author": "Grudge Studio",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5000",
    "dev:server": "node server.js",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev\"",
    "build": "vite build",
    "start": "node server.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "discord.js": "^14.25.1",
    "express": "^5.2.1",
    "framer-motion": "^12.34.0",
    "pg": "^8.18.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.3",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "vite": "^7.3.1"
  }
}
