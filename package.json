{
  "name": "grudge-warlords-mmo",
  "version": "1.0.0",
  "description": "Grudge Warlords MMO - Server infrastructure and deployment tools",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "build": "bash scripts/build-server.sh",
    "deploy": "bash scripts/deploy-to-vps.sh",
    "cli": "node scripts/grudge-cli.js",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "mmo",
    "game-server",
    "unity",
    "grudge-warlords"
  ],
  "author": "Grudge Warlords Team",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "pg": "^8.11.0",
    "redis": "^4.6.7",
    "winston": "^3.9.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.22"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
