# Grudge Warlords MMO - Production Environment Configuration
# Copy this file to .env and configure with your actual values

# Server Configuration
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# VPS Configuration
VPS_HOST=your-vps-hostname-or-ip
VPS_USER=root
VPS_SSH_KEY_PATH=~/.ssh/grudge_warlords_deploy_key
VPS_DEPLOY_PATH=/var/www/grudge-warlords

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=grudge_warlords
DB_USER=grudge_admin
DB_PASSWORD=your-secure-password-here
DB_SSL=true

# Redis Configuration (for session management and caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here

# Unity Server Configuration
UNITY_SERVER_PORT=7777
UNITY_MAX_PLAYERS=100
UNITY_TICK_RATE=30

# AI Configuration
OPENAI_API_KEY=your-openai-api-key-here
AI_MODEL=gpt-4
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.7

# Authentication & Security
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRY=24h
ADMIN_API_KEY=your-admin-api-key-here

# Build Configuration
BUILD_ENV=production
UNITY_BUILD_PATH=./builds/server
UNITY_VERSION=2022.3.10f1

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/grudge-warlords.log

# Monitoring
SENTRY_DSN=your-sentry-dsn-here
ENABLE_METRICS=true
METRICS_PORT=9090

# Game Server Configuration
GAME_SERVER_NAME=Grudge Warlords Official Server
GAME_SERVER_REGION=us-east-1
GAME_MAX_CONCURRENT_GAMES=50
