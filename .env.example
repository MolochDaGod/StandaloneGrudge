# Grudge Warlords - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# PUBLIC URL (Required for OAuth redirects)
# ===========================================
# Set this to your deployed URL (e.g., https://your-app.vercel.app or https://grudgewarlords.com)
PUBLIC_URL=

# ===========================================
# DISCORD OAUTH & BOT (Required)
# ===========================================
# Get these from https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Discord webhook for arena announcements (optional)
DISCORD_GRUDGE_WEBHOOK=

# ===========================================
# DATABASE (Required)
# ===========================================
# PostgreSQL connection string for GRUDA-Wars local game state
GRUDGE_ACCOUNT_DB=postgresql://user:password@host:5432/database?sslmode=require

# ===========================================
# WARLORD-CRAFTING-SUITE DATABASE (Required for crafting/inventory)
# ===========================================
# Neon PostgreSQL connection string — same DB used by the Warlord-Crafting-Suite
# Enables crafting, account-wide inventory, resources, profession progression
DATABASE_URL=postgresql://user:password@neon-host:5432/neondb?sslmode=require

# ===========================================
# SSO & CROSS-APP AUTH (Required for Crafting Suite integration)
# ===========================================
# Shared HMAC secret — MUST match SESSION_SECRET in Warlord-Crafting-Suite
# Both apps use this to sign/verify SSO tokens
SSO_SECRET=your-shared-sso-secret-here

# ===========================================
# ADMIN & API KEYS (Optional)
# ===========================================
# Admin token for webhook management (defaults to DISCORD_BOT_TOKEN if not set)
GAME_API_GRUDA=

# ===========================================
# OBJECTSTORE & CRAFTING SUITE
# ===========================================
# ObjectStore CDN base URL (GitHub Pages)
OBJECTSTORE_BASE=https://molochdagod.github.io/ObjectStore

# Warlord-Crafting-Suite base URL (for crafting/inventory/arsenal)
CRAFTING_SUITE_URL=https://warlord-crafting-suite.vercel.app

# ===========================================
# S3 ASSET STORAGE (Railway Object Storage)
# ===========================================
# Injected automatically by Railway via ${{grudge-assets.*}} references
BUCKET_NAME=
BUCKET_REGION=us-east-1
BUCKET_ENDPOINT=
BUCKET_ACCESS_KEY=
BUCKET_SECRET_KEY=

# ===========================================
# NODE ENVIRONMENT
# ===========================================
# Set to 'production' for deployed environments
NODE_ENV=development
